        <!-- D1: có nhiều board rảnh? -->
        <mxCell id="d1" value="Có nhiều board&lt;br&gt;cùng min_queue?" style="rhombus;whiteSpace=wrap;html=1;fontSize=11;" vertex="1" parent="1">
